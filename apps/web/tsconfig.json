// TypeScript config for SPA app source and strict checking.
{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client", "vitest/globals"],
    "baseUrl": "."
  },
  "include": ["src", "vite.config.ts", "tailwind.config.ts", "eslint.config.js"]
}

