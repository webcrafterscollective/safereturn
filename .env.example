# Environment variables for local dev and production. Copy this file to .env and edit values.
APP_NAME=fastapi-fullstack-prod
ENVIRONMENT=dev
LOG_LEVEL=INFO

# JWT and app secrets. Use strong random values in staging/prod.
JWT_SECRET=change-me-to-a-long-random-secret
SECRET_KEY=change-me-to-another-long-random-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
FINDER_SESSION_TTL_MINUTES=60

# Database.
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://app_user:app_password@postgres:5432/app_db

# CORS and host protections.
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173
TRUSTED_HOSTS=localhost,127.0.0.1

# Observability.
PROMETHEUS_ENABLED=true
REQUEST_TIMEOUT_SECONDS=30

# Frontend static path inside container/image.
FRONTEND_DIST_PATH=/app/web_dist

# Deployment/Caddy domain.
DOMAIN=localhost

# Optional: API image reference used by prod compose during deployment.
API_IMAGE=ghcr.io/your-org/fastapi-fullstack-prod/api:latest

# Frontend dev server API target (used by docker-compose.yml web service).
VITE_API_BASE_URL=http://localhost:8000
